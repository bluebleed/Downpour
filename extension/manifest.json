{
  "manifest_version": 3,
  "name": "Downpour Capture",
  "version": "0.1.0",
  "description": "Sends downloads from your browser to the Downpour app.",
  "permissions": ["downloads", "cookies", "tabs", "storage"],
  "host_permissions": ["http://127.0.0.1:53472/*", "<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_title": "Downpour Capture",
    "default_popup": "popup.html"
  }
}
