{
  "manifest_version": 3,
  "name": "Downpour Capture",
  "version": "0.1.0",
  "description": "Optionally sends new downloads to the local Downpour app.",
  "permissions": ["downloads", "storage", "contextMenus"],
  "host_permissions": ["http://127.0.0.1:53472/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Downpour Capture",
    "default_popup": "popup.html"
  }
}
