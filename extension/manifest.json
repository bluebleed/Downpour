{
  "manifest_version": 3,
  "name": "Downpour Capture",
  "version": "0.1.0",
  "description": "Sends downloads from your browser to the Downpour app.",
  "permissions": ["downloads"],
  "host_permissions": ["http://127.0.0.1:53472/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Downpour Capture",
    "default_popup": "popup.html"
  }
}
